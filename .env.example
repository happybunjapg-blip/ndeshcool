# Copy this file to .env and fill in your values.

# "memory" (default) needs nothing else below -- great for local dev/demo.
# "supabase" is the real production backend.
BACKEND=memory

# Only needed when BACKEND=supabase. Find these in your Supabase project's
# Settings -> API page. Use the "anon public" key for a client app like this.
SUPABASE_URL=
SUPABASE_KEY=
